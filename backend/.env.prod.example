# APP
SECRET_KEY=use-a-strong-random-secret
DEBUG=False
AUTH_MODE=ONLINE

# Auth cookie (access token is stored in an httpOnly cookie)
# COOKIE_SECURE MUST be True in production so the cookie is only sent over HTTPS.
COOKIE_SECURE=True
COOKIE_SAMESITE=lax

# Frontend (backend serves frontend on same origin)
FRONTEND_URL=https://your-domain.com

# Database (production)
# With AUTH_MODE=ONLINE the app defaults to PostgreSQL; set DATABASE_URL to
# point at your production database. (Leave unset only if AUTH_MODE=LOCAL/SQLite.)
DATABASE_URL=postgresql://user:password@db-host:5432/crowdroom

# Encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=use-a-generated-fernet-key

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://your-domain.com/api/v1/auth/spotify/callback
PLAYBACK_POLL_INTERVAL_SECONDS=3

# Metadata Cache
METADATA_CACHE_TTL_SECONDS=86400
METADATA_CACHE_MAX_SIZE=2048

# QR display device (ESP8266/ESP32 on LAN). Shared secret sent as
# X-Device-Token when the host pushes a QR to a LAN device. MUST be set
# in production — empty value disables auth and the device will reject
# requests with HTTP 401.
# Generate: openssl rand -hex 32
DEVICE_AUTH_TOKEN=
