# APP
SECRET_KEY=dev-secret-key-change-me
DEBUG=True
AUTH_MODE=LOCAL

# Auth cookie (access token is stored in an httpOnly cookie)
# COOKIE_SECURE stays False for local http. Set True in production (HTTPS).
COOKIE_SECURE=False
COOKIE_SAMESITE=lax

# Frontend (vite dev server)
FRONTEND_URL=http://localhost:5173

# Database
# Leave DATABASE_URL unset to let the app pick the backend from AUTH_MODE:
#   AUTH_MODE=LOCAL  -> SQLite (file in backend/, no external DB needed)
#   AUTH_MODE=ONLINE -> PostgreSQL
# Set it explicitly to override (e.g. point LOCAL dev at a local postgres):
# DATABASE_URL=postgresql://crowdroom:crowdroom@localhost:5432/crowdroom

# Encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=change-me

# Spotify (optional — per-user credentials used if not set)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/v1/auth/spotify/callback
PLAYBACK_POLL_INTERVAL_SECONDS=3

# PostgreSQL test database (optional, for concurrency tests)
# CROWDROOM_TEST_POSTGRES_URL=postgresql://user:pass@localhost:5432/crowdroom_test

# Metadata Cache
METADATA_CACHE_TTL_SECONDS=86400
METADATA_CACHE_MAX_SIZE=2048

# QR display device (ESP8266/ESP32 on LAN). Shared secret sent as
# X-Device-Token when the host pushes a QR to a LAN device.
# Generate: openssl rand -hex 32
DEVICE_AUTH_TOKEN=
