# APP
SECRET_KEY=MySecretKey123
DEBUG=False

# Auth Mode, use LOCAL (doesn't need email nor password) or ONLINE
AUTH_MODE=

# Database (Not needed if using default values)
# DATABASE_URL=sqlite:///./crowdroom.db

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/v1/auth/spotify/callback
PLAYBACK_POLL_INTERVAL_SECONDS=3

# Encryption
ENCRYPTION_KEY=CHANGE-ME-Un478hr7843nrf83u4n97834hf9745!"

# PostgreSQL test database (for concurrency tests, optional)
# CROWDROOM_TEST_POSTGRES_URL=postgresql://user:pass@localhost:5432/crowdroom_test

# Metadata Cache
METADATA_CACHE_TTL_SECONDS=86400
METADATA_CACHE_MAX_SIZE=2048
