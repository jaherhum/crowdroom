# Compose-flavored env file for the production Docker stack.
# Copy to `.env.production` and fill the secrets:
#   cp .env.production.example .env.production
# Generate strong secrets:
#   SECRET_KEY:     openssl rand -hex 32
#   ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   DEVICE_AUTH_TOKEN: openssl rand -hex 32

# --- App ---
SECRET_KEY=change-me-strong-random
DEBUG=False

# AUTH_MODE: ONLINE in Docker (Postgres-backed). LOCAL is for native dev only.
AUTH_MODE=ONLINE

# Auth cookie. Keep False on plain HTTP. Set True only behind an HTTPS-terminating
# reverse proxy (Caddy/Traefik/nginx).
COOKIE_SECURE=False
COOKIE_SAMESITE=lax

# Backend serves the SPA on the same origin in this image.
FRONTEND_URL=http://localhost:8000

# --- Database ---
# Postgres DSN matching the `db` service. Override host/credentials if pointing
# at an external Postgres instead of the bundled container.
DATABASE_URL=postgresql://crowdroom:crowdroom@db:5432/crowdroom

# Postgres credentials consumed by the `db` service (must match DATABASE_URL).
POSTGRES_USER=crowdroom
POSTGRES_PASSWORD=crowdroom
POSTGRES_DB=crowdroom

# --- Encryption ---
ENCRYPTION_KEY=change-me-fernet-key

# --- Spotify (optional, per-user creds used if blank) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/v1/auth/spotify/callback
PLAYBACK_POLL_INTERVAL_SECONDS=3

# --- Metadata cache ---
METADATA_CACHE_TTL_SECONDS=86400
METADATA_CACHE_MAX_SIZE=2048

# --- LAN QR display device shared secret ---
DEVICE_AUTH_TOKEN=

# --- API docs gate ---
# Comma-separated IPs/CIDRs allowed to reach /docs, /redoc, /openapi.json.
# Default-deny: only loopback. Widen for LAN access if needed.
DOCS_ALLOWED_HOSTS=127.0.0.1,::1
# Set True ONLY behind a trusted reverse proxy (X-Forwarded-For is spoofable).
DOCS_TRUST_PROXY=False
